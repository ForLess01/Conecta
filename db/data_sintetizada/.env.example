APP_NAME=Agro Price Prediction API
APP_ENV=development
APP_VERSION=1.0.0
API_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/agro_predictions

MODEL_REGISTRY_PATH=models/registry.json
INFERENCE_DATASET_PATH=data/processed/inference_dataset.csv
LATEST_PREDICTIONS_PATH=reports/predictions/latest_predictions.json

MODEL_CACHE_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200

DEFAULT_FORECAST_DAYS=7
MAX_FORECAST_DAYS=30

COMMISSION_COST_PER_KG=0.10
HANDLING_COST_PER_KG=0.08
ESTIMATED_LOSS_PERCENTAGE=0.03

UNSTABLE_MARKET_THRESHOLD=0.10
SELL_THRESHOLD=0.05
WAIT_THRESHOLD=-0.05
